NODE_ENV=production
PORT=4000
CLIENT_URL=https://icp-europe.nl

# Keep the application password URL-safe (letters, numbers, underscore, hyphen)
# or URL-encode it before placing it in this connection string.
MONGODB_URI=mongodb://itcp_training_app:CHANGE_ME_LONG_URL_SAFE_APP_PASSWORD@mongo:27017/itcp_training?authSource=itcp_training

JWT_ACCESS_SECRET=CHANGE_ME_RANDOM_ACCESS_SECRET_AT_LEAST_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_REFRESH_SECRET_AT_LEAST_32_CHARACTERS
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=itcp_refresh
COOKIE_DOMAIN=
COOKIE_SECURE=true

# Two proxy hops for: hosting-panel proxy -> application Nginx -> API.
# Use 1 only when port 8088 is exposed directly without another proxy.
TRUST_PROXY=2

UPLOAD_MAX_BYTES=5242880
UPLOADS_DIRECTORY=/app/server/uploads
SEED_UPDATE_EXISTING=false

INSTRUCTOR_REGISTRATION_ENABLED=false
INSTRUCTOR_REGISTRATION_CODE=
INSTRUCTOR_CODE_MAX_ATTEMPTS=5
INSTRUCTOR_CODE_WINDOW_MINUTES=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
