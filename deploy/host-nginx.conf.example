# TLS is expected to be managed by the hosting panel or the host Nginx.
# Confirm whether the required domain is icp-europe.nl or itcp-europe.nl
# before enabling the virtual host and requesting the certificate.

server {
  listen 80;
  server_name icp-europe.nl www.icp-europe.nl;

  location / {
    proxy_pass http://127.0.0.1:8088;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
