# Runtime
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
VITE_API_URL=/api/v1
# Optional override when uploaded media is served from a different origin.
VITE_MEDIA_ORIGIN=

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/itcp_training

# Authentication (replace every example value with a long, random secret)
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=itcp_refresh
COOKIE_DOMAIN=
# Leave blank for automatic behavior (false in development, true in production).
COOKIE_SECURE=
TRUST_PROXY=0

# Password recovery links are single-use and expire after this many minutes.
PASSWORD_RESET_TTL_MINUTES=30

# Instructor self-registration (backend only; never create a VITE_ version).
# Supply exactly six digits through the server environment/secret manager before enabling in production.
INSTRUCTOR_REGISTRATION_ENABLED=true
INSTRUCTOR_REGISTRATION_CODE=
INSTRUCTOR_CODE_MAX_ATTEMPTS=5
INSTRUCTOR_CODE_WINDOW_MINUTES=30

# Initial administrator (used only by `npm run seed:admin`)
ADMIN_NAME=ITCP Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Local media storage
UPLOAD_MAX_BYTES=5242880
UPLOADS_DIRECTORY=uploads

# Seed safety. Keep false to preserve CMS edits on existing seeded course codes.
# Set true only when intentionally restoring the canonical migrated course content.
SEED_UPDATE_EXISTING=false

# Google OAuth sign-in. Set all three together; leave all three blank to disable sign-in.
# Local callback: http://localhost:4000/api/v1/auth/google/callback
# Production callback: https://YOUR-DOMAIN/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Gmail API password-reset delivery. Generate a refresh token for the same Google OAuth client
# with the https://www.googleapis.com/auth/gmail.send scope and enable Gmail API in Google Cloud.
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_GMAIL_SENDER=
GOOGLE_GMAIL_SENDER_NAME=ITCP Training
