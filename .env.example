# Runtime
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
VITE_API_URL=/api/v1
# Optional override when uploaded media is served from a different origin.
VITE_MEDIA_ORIGIN=

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/itcp_training

# Authentication (replace every example value with a long, random secret)
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=itcp_refresh
COOKIE_DOMAIN=
# Leave blank for automatic behavior (false in development, true in production).
COOKIE_SECURE=
TRUST_PROXY=0

# Initial administrator (used only by `npm run seed:admin`)
ADMIN_NAME=ITCP Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Local media storage
UPLOAD_MAX_BYTES=5242880
UPLOADS_DIRECTORY=uploads

# Seed safety. Keep false to preserve CMS edits on existing seeded course codes.
# Set true only when intentionally restoring the canonical migrated course content.
SEED_UPDATE_EXISTING=false

# Optional Google OAuth. Set all three together; leave all three blank to disable it.
# Local callback example: http://localhost:4000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
