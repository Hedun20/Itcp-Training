# Runtime
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:4000/api/v1

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/itcp_training

# Authentication (replace every example value with a long, random secret)
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-32-character-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_COOKIE_NAME=itcp_refresh

# Initial administrator (used only by `npm run seed:admin`)
ADMIN_NAME=ITCP Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Local media storage
UPLOAD_MAX_BYTES=5242880
UPLOADS_DIRECTORY=uploads

# Optional Google OAuth. Leave blank to keep the provider safely disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
